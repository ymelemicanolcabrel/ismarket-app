{
  "name": "ismarket",
  "version": "5.0.0",
  "description": "ISMarket — Marketplace professionnelle Cameroun/Afrique",
  "scripts": {
    "serve": "npx serve public -p 3000",
    "deploy": "firebase deploy",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes",
    "cap:init": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:build": "npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0",
    "@capacitor/core": "^5.7.0",
    "@capacitor/android": "^5.7.0",
    "@capacitor/push-notifications": "^5.1.0",
    "@capacitor/geolocation": "^5.0.7",
    "firebase-tools": "^13.0.0"
  },
  "private": true
}
